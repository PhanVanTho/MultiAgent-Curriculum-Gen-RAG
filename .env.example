FLASK_SECRET_KEY=dev-secret-key-123
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Cấu hình crawling
SO_TRANG_HAT_GIONG=6
SO_TRANG_LIEN_KET=20
SO_DOAN_GUI_GEMINI=120

# Cấu hình Database: mysql, sqlite, mongodb
DB_TYPE=mysql
DB_USE_SQLITE=False
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=giao_trinh_ai
DB_PORT=3306

# Cấu hình MongoDB
MONGO_URI=mongodb://localhost:27017/giao_trinh_ai

# Cấu hình Azure Blob Storage (Tự động fallback về lưu trữ local nếu để trống)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=giao-trinh-ai-files
